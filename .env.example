# ======
# autoApply-ng Environment Variables
# ======

# Node Environment
NODE_ENV=development

# Database configuration (Prisma)
# Example: postgresql://user:password@localhost:5432/autoapply?schema=public
DATABASE_URL=""

# Claude AI (Anthropic) configuration for parsing/tailoring CVs
ANTHROPIC_API_KEY=""

# Redis configuration for BullMQ
REDIS_HOST="127.0.0.1"
REDIS_PORT="6379"

# ZeptoMail (Nodemailer) configuration for sending email notifications
ZEPTOMAIL_SMTP_HOST="smtp.zeptomail.com"
ZEPTOMAIL_SMTP_PORT="587"
ZEPTOMAIL_SMTP_USER=""
ZEPTOMAIL_SMTP_PASS=""
ZEPTOMAIL_FROM_ADDRESS="noreply@yourdomain.com"
ZEPTOMAIL_TO_ADDRESS="notifications@yourdomain.com"

# Indeed Search Parameters
INDEED_SEARCH_LOCATION="Lagos, Nigeria"
INDEED_SEARCH_QUERY="Software Engineer"
