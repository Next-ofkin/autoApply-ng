generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Job {
  id              String    @id @default(cuid())
  jobId           String    @unique
  title           String
  company         String
  location        String
  applyUrl        String
  description     String    @db.Text
  status          JobStatus @default(FOUND)
  tailoredCvPath  String?
  coverLetterPath String?
  matchScore      Int?
  appliedAt       DateTime?
  emailSentAt     DateTime?
  errorMessage    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model CvProfile {
  id              String   @id @default(cuid())
  skills          String[]
  keywords        String[]
  experienceLevel String
  yearsExperience Int
  domains         String[]
  rawAnalysis     String   @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum JobStatus {
  FOUND
  TAILORING
  READY
  APPLYING
  APPLIED
  FAILED
  SKIPPED
}